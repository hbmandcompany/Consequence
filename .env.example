# Shop domain hosts (comma-separated). Defaults: consequence.cc, www.consequence.cc
# NEXT_PUBLIC_SHOP_HOSTS=consequence.cc,www.consequence.cc

# Shop URL override (defaults to https://consequence.cc in production, /shop in dev)
# NEXT_PUBLIC_SHOP_URL=https://consequence.cc

# Main marketing site (defaults to https://consequence.software in production)
# NEXT_PUBLIC_MAIN_SITE_URL=https://consequence.software

MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=consequence_dev_key

# PostgreSQL — wire later; register SearchDatabaseAdapter in lib/search/db-sync.ts
# DATABASE_URL=postgresql://user:pass@localhost:5432/consequence
